    "import pandas as pd\n",
    "\n",
    "# Load your dataset\n",
    "df = pd.read_csv('../data/raw/spam_Emails_data.csv')\n",
    "\n",
    "# Randomly select 80,000 rows\n",
    "df_reduced = df.sample(n=80000, random_state=42)\n",
    "\n",
    "# Save the result\n",
    "df_reduced.to_csv('../data/processed/spam_email.csv', index=False)"
   ]
  }
